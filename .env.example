# ============================================================
# Vietnam Peaks — biến môi trường (MẪU)
# ------------------------------------------------------------
# Copy file này thành `.env.local` rồi điền giá trị thật:
#     cp .env.example .env.local
# `.env.local` đã bị .gitignore chặn — KHÔNG commit khoá thật.
#
# Lấy giá trị ở: Supabase Dashboard → Project Settings → API
# ============================================================

# --- Supabase (công khai — nhúng được vào client) ---
# URL project, dạng https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key: an toàn để lộ ở client; quyền bị giới hạn bởi RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (BÍ MẬT — chỉ dùng phía server) ---
# Service role key: BYPASS RLS. Chỉ dùng trong Server Actions / Route Handlers
# cho admin CRUD và kiểm duyệt UGC. TUYỆT ĐỐI không để rò ra client / không prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# URL gốc của site, dùng cho SEO/OG image, sitemap, và redirect của Supabase Auth.
# Dev: http://localhost:3000 — Prod: https://vietnampeaks.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
