# ============================================================
# Vietnam Peaks — .gitignore (Next.js + Supabase + macOS)
# ============================================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js / build ---
/.next/
/out/
/build
/dist
next-env.d.ts

# --- Production ---
*.tsbuildinfo

# --- Testing / coverage ---
/coverage

# --- Env (BÍ MẬT — không commit) ---
# Giữ lại .env.example làm mẫu; chặn mọi file env thật.
.env
.env.*
!.env.example

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# --- Vercel ---
.vercel

# --- Supabase CLI (nếu dùng local dev) ---
# Thư mục .supabase/ chứa state local; config & migrations thì NÊN commit.
.branches
.temp
supabase/.temp/

# --- IDE / Editor ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*

# --- Misc ---
*.pem
